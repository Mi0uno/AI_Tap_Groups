{
  "manifest_version": 3,
  "name": "AI Tab Grouper",
  "description": "Use a configured AI provider to organize Chrome or Edge tabs into native tab groups.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "AI Tab Grouper",
    "default_popup": "src/popup.html"
  },
  "commands": {
    "group-tabs": {
      "suggested_key": {
        "default": "Alt+Shift+G"
      },
      "description": "Group tabs with the configured AI provider"
    }
  }
}
